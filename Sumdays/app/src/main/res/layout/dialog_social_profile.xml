<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/profileDialogRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <LinearLayout
        android:id="@+id/userBlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/nickname"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginTop="24dp"
                android:layout_toEndOf="@id/profileImageCard"
                android:text="닉네임"
                android:textSize="@dimen/text_size_M"
                android:textStyle="bold" />

            <androidx.cardview.widget.CardView
                android:id="@+id/profileImageCard"
                android:layout_width="66dp"
                android:layout_height="66dp"
                android:layout_marginStart="18dp"
                android:layout_marginTop="18dp"
                android:layout_centerVertical="true"
                app:cardCornerRadius="33dp"
                app:cardElevation="0dp">

                <FrameLayout
                    android:id="@+id/profileImageContainer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/background"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <ImageView
                        android:id="@+id/imgPhoto"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />

                    <ImageView
                        android:id="@+id/imgBase"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerInside" />

                    <ImageView
                        android:id="@+id/imgMouth"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerInside" />

                    <ImageView
                        android:id="@+id/imgEyes"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerInside" />

                    <ImageView
                        android:id="@+id/imgAccessory"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerInside" />
                </FrameLayout>
            </androidx.cardview.widget.CardView>
        </RelativeLayout>

        <Button
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginHorizontal="10dp"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="12dp"
            android:elevation="0dp"
            android:stateListAnimator="@null"
            android:text="로그아웃"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="18dp" />
    </LinearLayout>

    <Button
        android:id="@+id/btnShop"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="14dp"
        android:elevation="0dp"
        android:stateListAnimator="@null"
        android:text="상점으로 가기"
        android:textSize="16sp"
        app:cornerRadius="18dp" />

    <Button
        android:id="@+id/btnCustomize"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="10dp"
        android:elevation="0dp"
        android:stateListAnimator="@null"
        android:text="커스터마이징"
        android:textSize="16sp"
        app:cornerRadius="18dp" />
</LinearLayout>
