<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"

    android:id="@+id/cardShopItem"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"

    app:cardBackgroundColor="#FFFFFF"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"

    app:strokeColor="@color/foxrange"
    app:strokeWidth="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="104dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="14dp">

        <!-- 아이템 이미지 -->
        <FrameLayout
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_shop_item_image"
            android:padding="6dp">

            <ImageView
                android:id="@+id/ivShopItemImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:src="@android:drawable/ic_menu_gallery"
                tools:ignore="ContentDescription" />

        </FrameLayout>

        <!-- 상품 정보 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- 이름 + 배지 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvShopItemName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="보라빛 저녁 테마"
                    android:textColor="#2D2A26"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    tools:text="보라빛 저녁 테마" />

                <TextView
                    android:id="@+id/tvPurchasedBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_label_owned"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="3dp"
                    android:text="보유중"
                    android:textColor="@android:color/white"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    tools:visibility="visible"
                    tools:text="보유 x3" />

            </LinearLayout>

            <!-- 설명 -->
            <TextView
                android:id="@+id/tvShopItemDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:maxLines="2"
                android:text="차분한 저녁 분위기의 배경과 포인트 색상을 적용해요"
                android:textColor="#7A726A"
                android:textSize="13sp"
                tools:text="차분한 저녁 분위기의 배경과 포인트 색상을 적용해요" />

        </LinearLayout>

        <!-- 가격 및 버튼 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvShopItemPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="320P"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="320P" />

            <Button
                android:id="@+id/btnShopItemAction"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginTop="10dp"
                android:backgroundTint="@color/foxrange"
                android:minWidth="72dp"
                android:text="구매"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                android:textStyle="bold"
                tools:text="구매" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>