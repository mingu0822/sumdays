<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    card_view:cardBackgroundColor="#FFFFFF"
    card_view:cardCornerRadius="18dp"
    card_view:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvProfileEmoji"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:gravity="center"
            android:background="#EFEAE2"
            android:text="😊"
            android:textSize="24sp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvSocialName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="민수"
                android:textColor="#222222"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSocialSummary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:maxLines="2"
                android:text="오늘은 좀 지쳤지만 그래도 버텼어"
                android:textColor="#555555"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvEmotion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="😌 평온 / 과제 / 회복"
                android:textColor="#7A6E5F"
                android:textSize="13sp" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnOpenSocial"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center_vertical"
            android:background="@android:color/transparent"
            android:contentDescription="open social"
            android:src="@android:drawable/ic_media_next" />
    </LinearLayout>

</androidx.cardview.widget.CardView>